# =============================================================================
# FACIS Cluster Credentials
# =============================================================================
# Copy to .env.cluster and fill in values.
# Used by scripts/demo_lakehouse.py for OIDC-authenticated Trino access.
# =============================================================================

# Keycloak OIDC credentials
FACIS_OIDC_USERNAME=<test-user>
FACIS_OIDC_PASSWORD=<password>
FACIS_OIDC_CLIENT_SECRET=<client-secret>

# Service endpoints (defaults shown — override if needed)
FACIS_KEYCLOAK_URL=<keycloak-url>
FACIS_TRINO_HOST=<trino-host>
FACIS_TRINO_PORT=<port>
FACIS_TRINO_CATALOG=<catalog-name>
